<%= I18n.t('responsibility_mailer.remind_group.message', name: Settings::Instance.name, days: @days) %>

<%= I18n.t('responsibility_mailer.remind_group.number') %><%= "\t" %><%= I18n.t('responsibility_mailer.remind_group.type') %><%= "\t" %><%= I18n.t('responsibility_mailer.remind_group.status') %><%= "\t" %><%= I18n.t('responsibility_mailer.remind_group.category') %><%= "\t" %><%= I18n.t('responsibility_mailer.remind_group.assigned_since') %>
<%= '*' * I18n.t('responsibility_mailer.remind_group.number').length %><%= "\t" %><%= '*' * I18n.t('responsibility_mailer.remind_group.type').length %><%= "\t" %><%= '*' * I18n.t('responsibility_mailer.remind_group.status').length %><%= "\t" %><%= '*' * I18n.t('responsibility_mailer.remind_group.category').length %><%= "\t" %><%= '*' * I18n.t('responsibility_mailer.remind_group.assigned_since').length %>

<% @issues.each do |issue| -%>
<%= [issue.id, MainCategory.human_enum_name(:kind, issue.kind),
     Issue.human_enum_name(:status, issue.status), issue.sub_category,
     l(issue.responsibility_since, format: :elaborate)].join("\t") %>
<% end -%>

<%= t :best_regards, name: Settings::Instance.name %>
